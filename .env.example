# Supabase — copy this file to .env.local and fill in real values
# Get these from: Supabase Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Dev auto-login (optional) — when both are set, the app signs in automatically
# in __DEV__ builds so you skip the login screen during local development.
# Create this account once in your Supabase Dashboard (Authentication → Users).
EXPO_PUBLIC_DEV_EMAIL=
EXPO_PUBLIC_DEV_PASSWORD=

